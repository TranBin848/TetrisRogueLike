;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Tetromancer"
run/main_scene="uid://bo2uw5yqwi2ox"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/singletons/game_manager.gd"
GameData="*res://scripts/singletons/game_data.gd"
EventManager="*res://scripts/singletons/event_manager.gd"
GameCamera="*res://scripts/board/game_camera.gd"
BlockChainReaction="*res://scripts/block_destroy_effects.gd"
Random="*res://scripts/singletons/rng.gd"
Transition="*res://scenes/transition.tscn"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="canvas_items"

